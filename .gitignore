# ════════════════════════════════════════════════════════════════
#  ECG System — .gitignore
#  Django 5 · PyTorch · Docker · Render deployment
# ════════════════════════════════════════════════════════════════


# ── Secrets & environment ──────────────────────────────────────
.env
*.env
!.env.example          # Keep the template; ignore actual secrets


# ── Python cache & compiled files ─────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]              # .pyc  .pyo  .pyd
*.pyd
*.pyo
.Python


# ── Virtual environments ───────────────────────────────────────
venv/
env/
.venv/
ENV/
.env/
pip-wheel-metadata/


# ── Django runtime files ───────────────────────────────────────
db.sqlite3             # SQLite dev database — never commit
staticfiles/           # Generated by collectstatic
media/
uploads/


# ── PyTorch / ML artefacts ────────────────────────────────────
*.pt                   # PyTorch model weights
*.pth
*.onnx
*.pkl                  # Pickled models / scalers
*.h5                   # Keras / HDF5 weights
*.npy
*.npz
model/weights/         # Custom model weight directories


# ── Data files (large / sensitive) ────────────────────────────
*.csv
*.xlsx
*.xls
*.parquet
*.feather
ecg_signal.csv


# ── Jupyter Notebooks ──────────────────────────────────────────
*.ipynb
.ipynb_checkpoints/


# ── Testing & coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.junit.xml


# ── Build & distribution ───────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/
*.egg
MANIFEST


# ── Docker (local convenience files) ──────────────────────────
# Keep Dockerfile and .dockerignore — they are part of the project.
# Exclude local override compose files.
docker-compose.override.yml


# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
celerybeat-schedule
celerybeat.pid


# ── Editor & IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db


# ── Node (if any frontend tooling) ────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── Misc ──────────────────────────────────────────────────────
*.bak
*.swp
*.tmp
*.orig
