# ── Git ────────────────────────────────────────────────────────────────────────
.git
.gitignore
.github

# ── Python cache ───────────────────────────────────────────────────────────────
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.Python

# ── Virtual environments ────────────────────────────────────────────────────────
env/
venv/
.venv/
ENV/

# ── Environment & secrets ───────────────────────────────────────────────────────
.env
*.env
# Keep .env.example in the image for documentation? No — exclude it too.
.env.example

# ── Jupyter / Notebooks ─────────────────────────────────────────────────────────
**/*.ipynb
.ipynb_checkpoints

# ── Django runtime files ────────────────────────────────────────────────────────
# SQLite is not used in production (PostgreSQL via DATABASE_URL)
db.sqlite3
media/
uploads/
# staticfiles/ is generated by collectstatic inside the container
staticfiles/

# ── Docker files themselves ──────────────────────────────────────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ── Editor & IDE ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Test / CI ───────────────────────────────────────────────────────────────────
.github/
.pytest_cache/
htmlcov/
.coverage

# ── Misc ────────────────────────────────────────────────────────────────────────
*.log
*.bak
*.swp
*.tmp
node_modules/
README.md
DOCKER_GUIDE.md
ecg_signal.csv
